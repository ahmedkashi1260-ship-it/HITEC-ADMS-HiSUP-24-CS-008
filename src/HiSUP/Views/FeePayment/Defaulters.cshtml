@model IEnumerable<HiSUP.Models.Student>
@{
    ViewData["Title"] = "Fee Defaulters";
}

<div class="page-header" style="background: linear-gradient(135deg, #e65100, #ffa726);">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fas fa-exclamation-triangle me-2"></i>Fee Defaulters</h2>
            <p>Students with outstanding fee balances</p>
        </div>
        <a href="/FeePayment" class="btn btn-light">
            <i class="fas fa-arrow-left me-2"></i>Back to Payments
        </a>
    </div>
</div>

<div class="table-card">
    <div class="card-header" style="background: linear-gradient(135deg, #e65100, #ffa726);">
        <i class="fas fa-list me-2"></i>Students List (@Model.Count() total)
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Roll No</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td><strong>@student.RollNumber</strong></td>
                        <td>@student.FirstName @student.LastName</td>
                        <td>@student.Department?.DeptName</td>
                        <td>
                            <a href="/FeePayment/Create" class="btn btn-sm btn-warning text-white">
                                <i class="fas fa-money-bill me-1"></i>Process Payment
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="alert alert-info mt-3">
    <i class="fas fa-info-circle me-2"></i>
    <strong>Note:</strong> This page uses the <code>vw_FeeDefaulters</code> database view in production —
    here it shows a simplified active-student list for demonstration.
</div>