@model IEnumerable<HiSUP.Models.FeePayment>
@{
    ViewData["Title"] = "Fee Payments";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fas fa-money-bill-wave me-2"></i>Fee Payments</h2>
            <p>View and process student fee payments</p>
        </div>
        <a href="/FeePayment/Create" class="btn btn-light btn-lg">
            <i class="fas fa-plus-circle me-2"></i>Process New Payment
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list me-2"></i>Payment History (@Model.Count() records)</span>
        <a href="/FeePayment/Defaulters" class="btn btn-sm btn-warning text-white">
            <i class="fas fa-exclamation-triangle me-1"></i>View Defaulters
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Receipt #</th>
                    <th>Student</th>
                    <th>Amount</th>
                    <th>Method</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model)
                {
                    <tr>
                        <td>#@payment.PaymentID.ToString("D5")</td>
                        <td>@payment.Student?.FirstName @payment.Student?.LastName</td>
                        <td><strong class="text-success">Rs. @payment.AmountPaid.ToString("N0")</strong></td>
                        <td>
                            <span class="badge bg-info">@payment.PaymentMethod</span>
                        </td>
                        <td>@payment.PaymentDate.ToString("dd-MMM-yyyy hh:mm tt")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>