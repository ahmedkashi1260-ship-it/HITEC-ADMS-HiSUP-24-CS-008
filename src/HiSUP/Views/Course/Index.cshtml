@model IEnumerable<HiSUP.Models.Course>
@{
    ViewData["Title"] = "Courses";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fas fa-book me-2"></i>Courses</h2>
            <p>Manage course catalog</p>
        </div>
        <a href="/Course/Create" class="btn btn-light btn-lg">
            <i class="fas fa-plus-circle me-2"></i>Add Course
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-card">
    <div class="card-header">
        <i class="fas fa-list me-2"></i>Course Catalog (@Model.Count() courses)
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Title</th>
                    <th>Credit Hours</th>
                    <th>Semester</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td><strong>@course.CourseCode</strong></td>
                        <td>@course.CourseTitle</td>
                        <td>@course.CreditHours</td>
                        <td>@course.Semester</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>