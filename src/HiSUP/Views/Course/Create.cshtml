@model HiSUP.Models.Course
@{
    ViewData["Title"] = "Add Course";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fas fa-book me-2"></i>Add New Course</h2>
            <p>Create a new course in the catalog</p>
        </div>
        <a href="/Course" class="btn btn-light">
            <i class="fas fa-arrow-left me-2"></i>Back to Courses
        </a>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="table-card">
            <div class="card-header">
                <i class="fas fa-plus-circle me-2"></i>Course Form
            </div>
            <div class="p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-hashtag me-1 text-primary"></i>Course Code
                            </label>
                            <input asp-for="CourseCode" class="form-control" placeholder="e.g. CS301" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">
                                <i class="fas fa-book-open me-1 text-primary"></i>Course Title
                            </label>
                            <input asp-for="CourseTitle" class="form-control" placeholder="e.g. Database Systems" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">
                                <i class="fas fa-clock me-1 text-primary"></i>Credit Hours
                            </label>
                            <input asp-for="CreditHours" type="number" class="form-control" min="1" max="6" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">
                                <i class="fas fa-calendar me-1 text-primary"></i>Semester
                            </label>
                            <input asp-for="Semester" type="number" class="form-control" min="1" max="8" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">
                                <i class="fas fa-project-diagram me-1 text-primary"></i>Program ID
                            </label>
                            <input asp-for="ProgramID" type="number" class="form-control" placeholder="e.g. 1" required />
                        </div>
                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="fas fa-save me-2"></i>Add Course
                            </button>
                            <a href="/Course" class="btn btn-outline-secondary btn-lg ms-2 px-5">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>