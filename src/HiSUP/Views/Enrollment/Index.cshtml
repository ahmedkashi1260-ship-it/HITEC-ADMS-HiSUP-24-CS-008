@model IEnumerable<HiSUP.Models.Enrollment>
@{
    ViewData["Title"] = "Enrollments";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fas fa-clipboard-list me-2"></i>Enrollments</h2>
            <p>View and manage student course enrollments</p>
        </div>
        <a href="/Enrollment/Create" class="btn btn-light btn-lg">
            <i class="fas fa-plus-circle me-2"></i>New Enrollment
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-card">
    <div class="card-header">
        <i class="fas fa-list me-2"></i>Enrollment Records (@Model.Count() total)
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Section</th>
                    <th>Enrollment Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var enrollment in Model)
                {
                    <tr>
                        <td>@enrollment.Student?.FirstName @enrollment.Student?.LastName</td>
                        <td>@enrollment.Section?.Course?.CourseTitle</td>
                        <td>@enrollment.Section?.SectionName</td>
                        <td>@enrollment.EnrollmentDate.ToString("dd-MMM-yyyy")</td>
                        <td>
                            @if (enrollment.Status == "Active")
                            {
                                <span class="badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-inactive">@enrollment.Status</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>